{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Run with .env",
      "request": "launch",
      "type": "dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    },
    {
      "name": "Flutter: Profile with .env",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    },
    {
      "name": "Flutter: Release with .env",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    }
  ]
}
